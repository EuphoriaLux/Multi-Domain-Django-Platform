{
  "name": "crush-lu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind-src/crush_lu/tailwind-input.css -o ./crush_lu/static/crush_lu/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./tailwind-src/crush_lu/tailwind-input.css -o ./crush_lu/static/crush_lu/css/tailwind.css --watch",
    "build:css:power-up": "tailwindcss -i ./tailwind-src/power_up/tailwind-input.css -o ./power_up/static/power_up/css/tailwind.css --minify",
    "watch:css:power-up": "tailwindcss -i ./tailwind-src/power_up/tailwind-input.css -o ./power_up/static/power_up/css/tailwind.css --watch",
    "build:css:tableau": "tailwindcss -i ./tailwind-src/tableau/tailwind-input.css -o ./tableau/static/tableau/css/tailwind.css --minify",
    "watch:css:tableau": "tailwindcss -i ./tailwind-src/tableau/tailwind-input.css -o ./tableau/static/tableau/css/tailwind.css --watch",
    "build:css:arborist": "tailwindcss -i ./tailwind-src/arborist/tailwind-input.css -o ./arborist/static/arborist/css/tailwind.css --minify",
    "watch:css:arborist": "tailwindcss -i ./tailwind-src/arborist/tailwind-input.css -o ./arborist/static/arborist/css/tailwind.css --watch",
    "build:css:all": "npm run build:css && npm run build:css:power-up && npm run build:css:tableau && npm run build:css:arborist",
    "format": "prettier --write \"**/*.{html,js,css}\"",
    "format:check": "prettier --check \"**/*.{html,js,css}\""
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "htmx.org": "^2.0.10"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.77",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.20",
    "@upstash/context7-mcp": "^3.2.2",
    "prettier": "^3.9.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.18"
  },
  "overrides": {
    "hono": "^4.12.25",
    "fast-uri": "^3.1.2",
    "ip-address": "^10.1.1",
    "undici": "^6.27.0",
    "qs": "^6.15.2"
  }
}
