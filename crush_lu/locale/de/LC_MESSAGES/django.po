msgid ""
"Display name: your full name or first name only (controlled by your 'Show "
"Full Name' setting)"
msgstr ""
"Anzeigename: Ihr vollständiger Name oder nur Ihr Vorname (gesteuert durch "
"Ihre Einstellung „Vollständigen Namen anzeigen“)"

#: .\crush_lu\templates\crush_lu\privacy_policy.html:312
