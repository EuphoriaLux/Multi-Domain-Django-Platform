msgstr "Netzwerkfehler. Bitte überprüfe deine Verbindung."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:55
msgid ""
"Firebase configuration missing. Phone verification is temporarily "
"unavailable."
msgstr ""
"Firebase-Konfiguration fehlt. Telefonverifizierung ist vorübergehend nicht "
"verfügbar."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:132
msgid ""
"Phone verification is temporarily unavailable. Please try again later or "
"contact support."
msgstr ""
"Telefonverifizierung ist vorübergehend nicht verfügbar. Bitte versuche es "
"später erneut oder kontaktiere den Support."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:158
msgid ""
"Phone verification service failed to initialize. Please refresh the page or "
"try again later."
msgstr ""
"Telefonverifizierungsdienst konnte nicht initialisiert werden. Bitte "
"aktualisiere die Seite oder versuche es später erneut."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:259
msgid "Please enter a valid phone number"
msgstr "Bitte gib eine gültige Telefonnummer ein"

#: .\crush_lu\static\crush_lu\js\phone-verification.js:310
msgid "No verification in progress. Please request a new code."
msgstr "Keine Verifizierung läuft. Bitte fordere einen neuen Code an."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:316
msgid "Please enter the 6-digit code"
msgstr "Bitte gib den 6-stelligen Code ein"

#: .\crush_lu\static\crush_lu\js\phone-verification.js:438
msgid ""
"Invalid phone number format. Please use international format (e.g., +352 XXX"
" XXX)"
msgstr ""
"Ungültiges Telefonnummernformat. Bitte verwende das internationale Format "
"(z.B. +352 XXX XXX)"

#: .\crush_lu\static\crush_lu\js\phone-verification.js:439
msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Zu viele Versuche. Bitte warte einige Minuten und versuche es erneut."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:440
msgid "Security verification failed. Please refresh the page and try again."
msgstr ""
"Sicherheitsüberprüfung fehlgeschlagen. Bitte aktualisiere die Seite und "
"versuche es erneut."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:441
msgid "Invalid code. Please check the code and try again."
msgstr "Ungültiger Code. Bitte überprüfe den Code und versuche es erneut."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:442
msgid "Code expired. Please request a new code."
msgstr "Code abgelaufen. Bitte fordere einen neuen Code an."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:443
msgid "SMS quota exceeded. Please try again later."
msgstr "SMS-Kontingent überschritten. Bitte versuche es später erneut."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:444
msgid "This phone number has been disabled. Please contact support."
msgstr "Diese Telefonnummer wurde deaktiviert. Bitte kontaktiere den Support."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:445
msgid "Phone authentication is not enabled. Please contact support."
msgstr ""
"Telefonauthentifizierung ist nicht aktiviert. Bitte kontaktiere den Support."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:446
#: .\crush_lu\static\crush_lu\js\phone-verification.js:455
msgid ""
"SMS service temporarily unavailable. Please wait a few minutes and try "
"again."
msgstr ""
"SMS-Dienst vorübergehend nicht verfügbar. Bitte warte einige Minuten und "
"versuche es erneut."

#: .\crush_lu\static\crush_lu\js\phone-verification.js:458
msgid "An error occurred. Please try again."
msgstr "Ein Fehler ist aufgetreten. Bitte versuche es erneut."

#: .\crush_lu\static\crush_lu\js\push-notifications.js:217
msgid ""
"Push service error. This may be due to server misconfiguration or network "
"issues. Please try again later."
msgstr ""
"Push-Dienst-Fehler. Dies kann auf eine Serverkonfigurationsfehler oder "
"Netzwerkprobleme zurückzuführen sein. Bitte versuche es später erneut."

#: .\crush_lu\static\crush_lu\js\push-notifications.js:220
msgid ""
"Push notifications are blocked. Please enable them in your browser settings."
msgstr ""
"Push-Benachrichtigungen sind blockiert. Bitte aktiviere diese in deinen "
"Browsereinstellungen."

#: .\crush_lu\static\crush_lu\js\push-notifications.js:222
msgid "Push subscription already exists or is in an invalid state."
msgstr ""
"Push-Abonnement existiert bereits oder befindet sich in einem ungültigen "
"Zustand."

#: .\crush_lu\static\crush_lu\js\push-notifications.js:276
msgid "Failed to unsubscribe"
msgstr "Abmeldung fehlgeschlagen"

#. user-facing string from alpine-components.js (#321)
msgid "Failed to generate ticket."
msgstr "Ticket konnte nicht erstellt werden."

#. user-facing string from alpine-components.js (#321)
msgid "Network error. Please try again."
msgstr "Netzwerkfehler. Bitte versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "QR scanner library not loaded."
msgstr "QR-Scanner-Bibliothek nicht geladen."

#. user-facing string from alpine-components.js (#321)
msgid ""
"Camera permission denied. Please allow camera access in your browser "
"settings (click the lock icon in the address bar) and try again."
msgstr ""
"Kamerazugriff verweigert. Bitte erlaube den Kamerazugriff in deinen "
"Browsereinstellungen (klicke auf das Schloss-Symbol in der Adressleiste) und"
" versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "No camera found on this device."
msgstr "Auf diesem Gerät wurde keine Kamera gefunden."

#. user-facing string from alpine-components.js (#321)
msgid ""
"Camera is in use by another application. Please close other apps using the "
"camera and try again."
msgstr ""
"Die Kamera wird von einer anderen Anwendung verwendet. Bitte schließe andere"
" Apps, die die Kamera nutzen, und versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "Could not start camera: "
msgstr "Kamera konnte nicht gestartet werden: "

#. user-facing string from alpine-components.js (#321)
msgid "Check-in failed."
msgstr "Check-in fehlgeschlagen."

#. user-facing string from alpine-components.js (#321)
msgid "Network error or invalid QR code."
msgstr "Netzwerkfehler oder ungültiger QR-Code."

#. user-facing string from alpine-components.js (#321)
msgid "Subscription refreshed successfully"
msgstr "Abonnement erfolgreich aktualisiert"

#. user-facing string from alpine-components.js (#321)
msgid "Failed to refresh subscription"
msgstr "Abonnement konnte nicht aktualisiert werden"

#. user-facing string from alpine-components.js (#321)
msgid "Error refreshing subscription"
msgstr "Fehler beim Aktualisieren des Abonnements"

#. user-facing string from alpine-components.js (#321)
msgid ""
"Push notification system not loaded. Please refresh the page and try again."
msgstr ""
"Das Push-Benachrichtigungssystem ist nicht geladen. Bitte aktualisiere die "
"Seite und versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "Photo upload failed: "
msgstr "Foto-Upload fehlgeschlagen: "

#. user-facing string from alpine-components.js (#321)
msgid "Photo upload failed. Please try again."
msgstr "Foto-Upload fehlgeschlagen. Bitte versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "Could not remove the photo: "
msgstr "Foto konnte nicht entfernt werden: "

#. user-facing string from alpine-components.js (#321)
msgid "Could not remove the photo. Please try again."
msgstr "Foto konnte nicht entfernt werden. Bitte versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "Network error. Please check your connection and try again."
msgstr ""
"Netzwerkfehler. Bitte überprüfe deine Verbindung und versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "Something went wrong. Please try again."
msgstr "Etwas ist schiefgelaufen. Bitte versuche es erneut."

#. user-facing string from alpine-components.js (#321)
msgid "Claim failed"
msgstr "Beanspruchung fehlgeschlagen"

#. user-facing string from alpine-components.js (#321)
msgid "Network error"
msgstr "Netzwerkfehler"

#. user-facing string from alpine-components.js (#321)
msgid "Import failed."
msgstr "Import fehlgeschlagen."

